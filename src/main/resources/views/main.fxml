<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>

<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox spacing="15"
      alignment="CENTER"
      stylesheets="@../styles/login.css"
      styleClass="login-container"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="PDVix.controllers.LoginController">

<VBox spacing="0" styleClass="title-login" alignment="CENTER">
    <ImageView fitHeight="80" fitWidth="200">
        <image>
            <Image url="@../img/logo.png" />
        </image>
    </ImageView>
    <Text styleClass="title-text-login" text="Ponto de Venda Enterprise"/>
</VBox>

<VBox styleClass="input-wrapper">
    <Label labelFor="$loginField" text="LOGIN (cpf)" />
    <TextField
            fx:id="loginField"
            promptText="Cpf ou Usuário"
            styleClass="input"/>
</VBox>
<VBox styleClass="input-wrapper">
    <Label labelFor="$passwordField" text="SENHA" />

    <PasswordField
            fx:id="passwordField"
            promptText="Senha"
            styleClass="input"/>
</VBox>

<Button
        text="Entrar"
        styleClass="botao-login"
        onAction="#handleLogin"/>

</VBox>